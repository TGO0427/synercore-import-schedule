# Database Configuration
# Get this from Railway dashboard or run: railway variables
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.proxy.rlwy.net:YOUR_PORT/railway

# Alternative: Use individual PostgreSQL variables (Railway provides these)
# PGHOST=YOUR_HOST.proxy.rlwy.net
# PGPORT=YOUR_PORT
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=YOUR_PASSWORD

# Application Configuration
NODE_ENV=development
PORT=5000

# Security Configuration
# CRITICAL: Generate a strong random secret for JWT tokens
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-and-random-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-very-long-and-random-refresh-secret-change-this-in-production

# SSL Configuration (only for local development)
# Set to 'true' only if you need to disable SSL verification in development
# NEVER set this to 'true' in production
DISABLE_SSL_VERIFY=false

# CORS Configuration - Allowed origins
# Format: comma-separated list of allowed domains
# Default includes localhost variants and Vercel deployment
FRONTEND_URL=https://your-frontend-domain.vercel.app
ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://www.your-frontend-domain.com

# Client Configuration
VITE_API_BASE_URL=http://localhost:5000
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Email/Notification Configuration
# Option 1: SMTP (Gmail, SendGrid, custom SMTP servers)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Option 2: SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Email settings
NOTIFICATION_EMAIL_FROM=noreply@synercore.com

# Email Importer (IMAP) Configuration
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password
# EMAIL_HOST=imap.gmail.com

# Sentry (server-side error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Logging
# LOG_LEVEL=INFO

# Database Pool Tuning (optional)
# PG_POOL_MAX=20
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=10000

# Force SSL for database connection (optional, auto-detected on Railway)
# FORCE_DB_SSL=0
